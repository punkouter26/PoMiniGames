erDiagram
    PLAYER_STATS {
        string PlayerId PK "Unique player identifier"
        string PlayerName "Display name"
        int TotalWins "Computed: Easy+Medium+Hard wins"
        int TotalLosses "Computed aggregate"
        int TotalDraws "Computed aggregate"
        int TotalGames "Computed aggregate"
        float WinRate "TotalWins/TotalGames"
        datetime CreatedAt
        datetime UpdatedAt
    }

    DIFFICULTY_STATS {
        string PlayerId FK "References PLAYER_STATS"
        string Difficulty "Easy | Medium | Hard"
        int Wins
        int Losses
        int Draws
        int TotalGames
        int WinStreak "Current consecutive wins"
        float WinRate "Wins/TotalGames"
    }

    SNAKE_HIGH_SCORE {
        string Initials "1-3 char player initials"
        string Date "ISO date string"
        int Score "Final score"
        int SnakeLength "Length at game end"
        int FoodEaten "Total food consumed"
        float GameDuration "Seconds played"
    }

    PO_DROP_SQUARE_HIGH_SCORE {
        string PlayerInitials "1-3 char player initials"
        string Date "ISO date string"
        float SurvivalTime "Seconds survived"
        string PlayerName "Optional full name"
    }

    RACER {
        int Id PK "Racer identifier"
        string Name "Racer display name"
        string Color "Hex color for rendering"
        float OddsToWin "Betting odds multiplier"
        float Speed "Base speed parameter"
        float Position "Current race position 0-1"
    }

    RACE_SESSION {
        string SessionId PK "Unique session GUID"
        string Status "Lobby | Betting | Racing | Finished"
        datetime CreatedAt
        int CurrentRound "Round number"
        string WinnerName "Populated on Finished"
    }

    PLAYER_STATS ||--o{ DIFFICULTY_STATS : "tracks per difficulty"
    RACE_SESSION ||--o{ RACER : "contains racers"
